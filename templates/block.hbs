{{! RQ CVE Risk Data — block.hbs }}
<div class="rq-container">

  {{! ── Core Fields ── }}
  {{#if hasStatus}}
    <div>
      <span class="p-key">Status:</span>
      <span class="p-value">
        <span class="rq-status-pill {{statusClass}}">{{details.status}}</span>
      </span>
    </div>
  {{/if}}

  <div>
    <span class="p-key">CVSS Score:</span>
    <span class="p-value {{cvssColorClass}}">{{details.cvssScore}}</span>
  </div>

  <div>
    <span class="p-key">EPSS Score:</span>
    <span class="p-value">{{details.epssScore}}</span>
  </div>

  <div>
    <span class="p-key">Financial Risk:</span>
    <span class="p-value rq-financial">{{details.contributoryEffect}}</span>
  </div>

  <div>
    <span class="p-key">Assets Affected:</span>
    <span class="p-value">{{details.assetsCount}}</span>
  </div>

  {{#if hasCriticalAssets}}
    <div>
      <span class="p-key">Critical Assets:</span>
      <span class="p-value rq-score-critical">{{details.criticalAssetsCount}}</span>
    </div>
  {{/if}}

  {{! ── Assets Dropdown ── }}
  {{#if hasAssets}}
    <div class="rq-section-toggle" {{action "toggleSection" "Assets"}}>
      <span class="p-title">
        {{fa-icon "server" fixedWidth=true}}
        Affected Assets
        <span class="rq-count">({{details.assetsCount}})</span>
      </span>
      <span class="rq-chevron">
        {{#if block._state.showAssets}}
          {{fa-icon "chevron-up"}}
        {{else}}
          {{fa-icon "chevron-down"}}
        {{/if}}
      </span>
    </div>
    {{#if block._state.showAssets}}
      <div class="rq-section-body">
        {{#each details.assets as |asset|}}
          <div class="rq-asset-entry">
            <div>
              <span class="p-key">Asset Name:</span>
              <span class="p-value">{{asset.name}}</span>
            </div>
            {{#if asset.ips}}
              <div>
                <span class="p-key">IP Address:</span>
                <span class="p-value rq-pill-value">
                  {{#each asset.ips as |ip|}}
                    <span class="pill-tag">{{ip}}</span>
                  {{/each}}
                </span>
              </div>
            {{/if}}
            <div>
              <span class="p-key">Endpoint Score:</span>
              <span class="p-value">{{asset.endpointScoring}}</span>
            </div>
          </div>
        {{/each}}
      </div>
    {{/if}}
  {{/if}}

  {{! ── MITRE ATT&CK Techniques Dropdown ── }}
  {{#if hasTechniques}}
    <div class="rq-section-toggle" {{action "toggleSection" "Techniques"}}>
      <span class="p-title">
        {{fa-icon "shield-alt" fixedWidth=true}}
        MITRE ATT&amp;CK Techniques
        <span class="rq-count">({{details.techniques.length}})</span>
      </span>
      <span class="rq-chevron">
        {{#if block._state.showTechniques}}
          {{fa-icon "chevron-up"}}
        {{else}}
          {{fa-icon "chevron-down"}}
        {{/if}}
      </span>
    </div>
    {{#if block._state.showTechniques}}
      <div class="rq-section-body">
        {{#each details.techniques as |technique|}}
          <div>
            <span class="p-key rq-technique-id">{{technique.id}}:</span>
            <span class="p-value">{{technique.name}}</span>
          </div>
        {{/each}}
      </div>
    {{/if}}
  {{/if}}

  {{! ── Data Sources Dropdown ── }}
  {{#if hasSources}}
    <div class="rq-section-toggle" {{action "toggleSection" "Sources"}}>
      <span class="p-title">
        {{fa-icon "database" fixedWidth=true}}
        Data Sources
        <span class="rq-count">({{details.sources.length}})</span>
      </span>
      <span class="rq-chevron">
        {{#if block._state.showSources}}
          {{fa-icon "chevron-up"}}
        {{else}}
          {{fa-icon "chevron-down"}}
        {{/if}}
      </span>
    </div>
    {{#if block._state.showSources}}
      <div class="rq-section-body">
        <div>
          <span class="p-key">Sources:</span>
          <span class="p-value rq-pill-value">
            {{#each details.sources as |source|}}
              <span class="pill-tag">{{source}}</span>
            {{/each}}
          </span>
        </div>
      </div>
    {{/if}}
  {{/if}}

  {{! ── Compensating Controls Dropdown ── }}
  {{#if hasCompensatingControls}}
    <div class="rq-section-toggle" {{action "toggleSection" "Controls"}}>
      <span class="p-title">
        {{fa-icon "shield-check" fixedWidth=true}}
        Compensating Controls
        <span class="rq-count">({{details.compensatingControls.length}})</span>
      </span>
      <span class="rq-chevron">
        {{#if block._state.showControls}}
          {{fa-icon "chevron-up"}}
        {{else}}
          {{fa-icon "chevron-down"}}
        {{/if}}
      </span>
    </div>
    {{#if block._state.showControls}}
      <div class="rq-section-body">
        {{#each details.compensatingControls as |control|}}
          <div class="rq-control-entry">
            {{#if control.name}}
              <div>
                <span class="p-key">Control:</span>
                <span class="p-value">{{control.name}}</span>
              </div>
            {{/if}}
            {{#if control.description}}
              <div>
                <span class="p-key">Description:</span>
                <span class="p-value">{{control.description}}</span>
              </div>
            {{/if}}
            {{#if control.type}}
              <div>
                <span class="p-key">Type:</span>
                <span class="p-value">{{control.type}}</span>
              </div>
            {{/if}}
            {{#if (not (or control.name control.description control.type))}}
              <div>
                <span class="p-value">{{control}}</span>
              </div>
            {{/if}}
          </div>
        {{/each}}
      </div>
    {{/if}}
  {{/if}}

  {{! ── Timeline Dropdown ── }}
  <div class="rq-section-toggle" {{action "toggleSection" "Timeline"}}>
    <span class="p-title">
      {{fa-icon "calendar-alt" fixedWidth=true}}
      Timeline
    </span>
    <span class="rq-chevron">
      {{#if block._state.showTimeline}}
        {{fa-icon "chevron-up"}}
      {{else}}
        {{fa-icon "chevron-down"}}
      {{/if}}
    </span>
  </div>
  {{#if block._state.showTimeline}}
    <div class="rq-section-body">
      <div>
        <span class="p-key">Published:</span>
        <span class="p-value">{{details.publishDate}}</span>
      </div>
      <div>
        <span class="p-key">Last Updated:</span>
        <span class="p-value">{{details.updateDate}}</span>
      </div>
    </div>
  {{/if}}

</div>
