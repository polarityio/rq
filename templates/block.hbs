{{! RQ CVE Risk Data — block.hbs }}
<div class="rq-container">

  {{! ── Header: CVE name + status pill ── }}
  <div class="rq-header">
    <span class="rq-cve-id">{{details.cveName}}</span>
    {{#if hasStatus}}
      <span class="rq-status-pill {{statusClass}}">{{details.status}}</span>
    {{/if}}
  </div>

  {{! ── Core scores row ── }}
  <div class="rq-scores-row">
    <div class="rq-score-block">
      <div class="rq-score-label">CVSS</div>
      <div class="rq-score-value {{cvssColorClass}}">{{details.cvssScore}}</div>
    </div>
    <div class="rq-score-divider"></div>
    <div class="rq-score-block">
      <div class="rq-score-label">EPSS</div>
      <div class="rq-score-value">{{details.epssScore}}</div>
    </div>
    <div class="rq-score-divider"></div>
    <div class="rq-score-block">
      <div class="rq-score-label">Financial Risk</div>
      <div class="rq-score-value rq-financial">{{details.contributoryEffect}}</div>
    </div>
    <div class="rq-score-divider"></div>
    <div class="rq-score-block">
      <div class="rq-score-label">Assets</div>
      <div class="rq-score-value">{{details.assetsCount}}</div>
    </div>
  </div>

  {{! ── Assets Dropdown ── }}
  {{#if hasAssets}}
    <div class="rq-section-toggle" {{action "toggleSection" "Assets"}}>
      <span class="p-title">
        {{fa-icon "server" fixedWidth=true}}
        Affected Assets
        <span class="rq-count">({{details.assetsCount}})</span>
      </span>
      <span class="rq-chevron">
        {{#if block._state.showAssets}}
          {{fa-icon "chevron-up"}}
        {{else}}
          {{fa-icon "chevron-down"}}
        {{/if}}
      </span>
    </div>
    {{#if block._state.showAssets}}
      <div class="rq-section-body">
        {{#each details.assets as |asset|}}
          <div class="rq-asset-row">
            <div class="rq-asset-header">
              <span class="rq-asset-name">{{asset.name}}</span>
              <span class="rq-asset-score">Score: {{asset.endpointScoring}}</span>
            </div>
            {{#if asset.ips}}
              <div class="rq-asset-ips">
                {{#each asset.ips as |ip|}}
                  <span class="pill-tag">{{ip}}</span>
                {{/each}}
              </div>
            {{/if}}
          </div>
        {{/each}}
      </div>
    {{/if}}
  {{/if}}

  {{! ── MITRE ATT&CK Techniques Dropdown ── }}
  {{#if hasTechniques}}
    <div class="rq-section-toggle" {{action "toggleSection" "Techniques"}}>
      <span class="p-title">
        {{fa-icon "shield-alt" fixedWidth=true}}
        MITRE ATT&amp;CK Techniques
        <span class="rq-count">({{details.techniques.length}})</span>
      </span>
      <span class="rq-chevron">
        {{#if block._state.showTechniques}}
          {{fa-icon "chevron-up"}}
        {{else}}
          {{fa-icon "chevron-down"}}
        {{/if}}
      </span>
    </div>
    {{#if block._state.showTechniques}}
      <div class="rq-section-body">
        {{#each details.techniques as |technique|}}
          <div class="rq-kv-row">
            <span class="p-key rq-technique-id">{{technique.id}}</span>
            <span class="p-value">{{technique.name}}</span>
          </div>
        {{/each}}
      </div>
    {{/if}}
  {{/if}}

  {{! ── Data Sources Dropdown ── }}
  {{#if hasSources}}
    <div class="rq-section-toggle" {{action "toggleSection" "Sources"}}>
      <span class="p-title">
        {{fa-icon "database" fixedWidth=true}}
        Data Sources
        <span class="rq-count">({{details.sources.length}})</span>
      </span>
      <span class="rq-chevron">
        {{#if block._state.showSources}}
          {{fa-icon "chevron-up"}}
        {{else}}
          {{fa-icon "chevron-down"}}
        {{/if}}
      </span>
    </div>
    {{#if block._state.showSources}}
      <div class="rq-section-body">
        <div class="rq-pills-row">
          {{#each details.sources as |source|}}
            <span class="pill-tag">{{source}}</span>
          {{/each}}
        </div>
      </div>
    {{/if}}
  {{/if}}

  {{! ── Timeline Dropdown ── }}
  <div class="rq-section-toggle" {{action "toggleSection" "Timeline"}}>
    <span class="p-title">
      {{fa-icon "calendar-alt" fixedWidth=true}}
      Timeline
    </span>
    <span class="rq-chevron">
      {{#if block._state.showTimeline}}
        {{fa-icon "chevron-up"}}
      {{else}}
        {{fa-icon "chevron-down"}}
      {{/if}}
    </span>
  </div>
  {{#if block._state.showTimeline}}
    <div class="rq-section-body">
      <div class="rq-kv-row">
        <span class="p-key">Published</span>
        <span class="p-value">{{details.publishDate}}</span>
      </div>
      <div class="rq-kv-row">
        <span class="p-key">Last Updated</span>
        <span class="p-value">{{details.updateDate}}</span>
      </div>
    </div>
  {{/if}}

</div>
