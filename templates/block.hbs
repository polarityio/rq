{{! RQ CVE Risk Data — block.hbs }}
<div class="rq-block">

  {{! Summary Row }}
  <div class="rq-summary-row">
    <span class="p-key">CVE:</span>
    <span class="p-value rq-cve-name">{{details.cveName}}</span>
    {{#if hasStatus}}
      <span class="rq-pill rq-status-pill {{statusClass}}">
        {{details.status}}
      </span>
    {{/if}}
  </div>

  <hr class="rq-divider">

  {{! Vulnerability Scores }}
  <div class="rq-section-title">Vulnerability Scores</div>
  <div class="rq-row">
    <span class="p-key">CVSS Score</span>
    <span class="p-value rq-score {{cvssColorClass}}">{{details.cvssScore}}</span>
  </div>
  <div class="rq-row">
    <span class="p-key">EPSS Score</span>
    <span class="p-value">{{details.epssScore}}</span>
  </div>

  <hr class="rq-divider">

  {{! Financial Risk }}
  <div class="rq-section-title">Financial Risk</div>
  <div class="rq-row">
    <span class="p-key">Contributory Effect</span>
    <span class="p-value rq-financial">{{details.contributoryEffect}}</span>
  </div>

  <hr class="rq-divider">

  {{! Asset Exposure }}
  <div class="rq-section-title">Asset Exposure</div>
  <div class="rq-row">
    <span class="p-key">Total Assets Affected</span>
    <span class="p-value">{{details.assetsCount}}</span>
  </div>
  <div class="rq-row">
    <span class="p-key">Critical Assets Affected</span>
    <span class="p-value {{if hasCriticalAssets "rq-critical"}}">{{details.criticalAssetsCount}}</span>
  </div>

  {{! Asset List }}
  {{#if hasAssets}}
    <div class="rq-asset-list">
      {{#each details.assets as |asset|}}
        <div class="rq-asset-row">
          <div class="rq-asset-header">
            <span class="rq-asset-name">{{asset.name}}</span>
            <span class="rq-asset-score">{{asset.endpointScoring}}</span>
          </div>
          <div class="rq-asset-ips">
            {{#each asset.ips as |ip|}}
              <span class="rq-ip-tag">{{ip}}</span>
            {{/each}}
          </div>
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{! MITRE ATT&CK Techniques }}
  {{#if hasTechniques}}
    <hr class="rq-divider">
    <div class="rq-section-title">MITRE ATT&amp;CK Techniques</div>
    <div class="rq-techniques">
      {{#each details.techniques as |technique|}}
        <div class="rq-row">
          <span class="p-key">{{technique.id}}</span>
          <span class="p-value rq-technique-name">{{technique.name}}</span>
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{! Compensating Controls }}
  {{#if hasCompensatingControls}}
    <hr class="rq-divider">
    <div class="rq-section-title">Compensating Controls</div>
    {{#each details.compensatingControls as |control|}}
      <div class="rq-row">
        <span class="p-value">{{control}}</span>
      </div>
    {{/each}}
  {{/if}}

  {{! Data Sources }}
  {{#if hasSources}}
    <hr class="rq-divider">
    <div class="rq-section-title">Data Sources</div>
    <div class="rq-sources">
      {{#each details.sources as |source|}}
        <span class="rq-source-tag">{{source}}</span>
      {{/each}}
    </div>
  {{/if}}

  <hr class="rq-divider">

  {{! Timeline }}
  <div class="rq-section-title">Timeline</div>
  <div class="rq-row">
    <span class="p-key">Published</span>
    <span class="p-value">{{details.publishDate}}</span>
  </div>
  <div class="rq-row">
    <span class="p-key">Last Updated</span>
    <span class="p-value">{{details.updateDate}}</span>
  </div>

</div>
